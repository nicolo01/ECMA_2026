y <- read.csv("data/captures.csv",sep=";")
y <- na.omit(y[,c("age", "sex")])
library(dplyr)
age.marginal.df <-
y %>%
group_by(age) %>%
summarise(n = n()) %>%
ungroup() %>%
mutate(prop = n/sum(n))
age.marginal.df
